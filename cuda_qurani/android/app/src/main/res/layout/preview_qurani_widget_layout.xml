<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:src="@drawable/qurani_logo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="8dp"
        android:text="Ayah Hari Ini"
        android:textColor="#B3FFFFFF"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="right" 
            android:textDirection="rtl"
            android:fontFamily="@font/uthmanic_hafs"
            android:text="فَإِنَّ مَعَ الْعُسْرِ يُسْرًا \uFD3F٥\uFD3E"
            android:textColor="#FFD700"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="2" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Karena sesungguhnya sesudah kesulitan itu ada kemudahan."
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:maxLines="2"
            android:gravity="start" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:text="Al-Inshirah: 5"
        android:textColor="#B3FFFFFF"
        android:textSize="11sp"
        android:textStyle="italic" />

</RelativeLayout>
