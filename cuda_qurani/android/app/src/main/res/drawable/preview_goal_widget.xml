<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background dengan gradient hijau -->
    <item>
        <shape>
            <gradient
                android:angle="315"
                android:startColor="#247C64"
                android:endColor="#1B5E20"
                android:type="linear" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#2D9A7E" />
        </shape>
    </item>
    
    <!-- Simulasi teks "Target Harian" (kiri atas) -->
    <item android:top="16dp" android:left="16dp" android:right="140dp" android:bottom="50dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <!-- Simulasi teks "0/10 Ayat" (kanan atas, warna gold) -->
    <item android:top="16dp" android:left="160dp" android:right="16dp" android:bottom="50dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFD700" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <!-- Progress Bar Track (abu-abu transparan) -->
    <item android:top="42dp" android:left="16dp" android:right="16dp" android:bottom="22dp">
        <shape android:shape="rectangle">
            <solid android:color="#40FFFFFF" />
            <corners android:radius="3dp" />
        </shape>
    </item>
    
    <!-- Progress Bar Fill (gold, 30% dari lebar) -->
    <item android:top="42dp" android:left="16dp" android:right="180dp" android:bottom="22dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFD700" />
            <corners android:radius="3dp" />
        </shape>
    </item>
</layer-list>