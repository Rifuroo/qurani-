<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background dengan gradient hijau -->
    <item>
        <shape>
            <gradient
                android:angle="315"
                android:startColor="#247C64"
                android:endColor="#1B5E20"
                android:type="linear" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#2D9A7E" />
        </shape>
    </item>
    
    <!-- Logo (kiri atas) -->
    <item android:top="16dp" android:left="16dp" android:right="200dp" android:bottom="90dp">
        <bitmap 
            android:src="@drawable/qurani_logo"
            android:gravity="top|start" />
    </item>

    <!-- Simulasi teks "Ayah of the Day" (di bawah logo) -->
    <item android:top="78dp" android:left="18dp" android:right="170dp" android:bottom="86dp">
        <shape android:shape="rectangle">
            <solid android:color="#B3FFFFFF" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <!-- Simulasi teks Arab (gold, 2 baris, rata kanan) -->
    <item android:top="60dp" android:left="80dp" android:right="16dp" android:bottom="76dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFD700" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <item android:top="78dp" android:left="100dp" android:right="16dp" android:bottom="58dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFD700" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <!-- Simulasi terjemahan (putih, 2 baris) -->
    <item android:top="102dp" android:left="16dp" android:right="60dp" android:bottom="38dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <item android:top="115dp" android:left="16dp" android:right="90dp" android:bottom="25dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <!-- Simulasi referensi (putih transparan, kanan bawah) -->
    <item android:top="132dp" android:left="180dp" android:right="16dp" android:bottom="16dp">
        <shape android:shape="rectangle">
            <solid android:color="#B3FFFFFF" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</layer-list>